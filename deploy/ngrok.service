[Unit]
Description=ngrok tunnel for PROJECT_APE65_A1 LINE webhook
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ape01
WorkingDirectory=/home/ape01
ExecStart=/usr/local/bin/ngrok http 5000 --log stdout
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
